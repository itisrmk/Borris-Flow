#!/usr/bin/env bash

set -euo pipefail

VERSION="1.0.0"
SCRIPT_NAME="$(basename "$0")"
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SCRIPT_SOURCE" ]; do
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
TEMPLATE_CLAUDE_DIR="${SCRIPT_DIR}/.claude"
TEMPLATE_CLAUDE_MD="${SCRIPT_DIR}/CLAUDE.md"

usage() {
  cat <<EOF
Usage:
  ${SCRIPT_NAME} init [TARGET_DIR] [--force]
  ${SCRIPT_NAME} --help
  ${SCRIPT_NAME} --version

Commands:
  init [TARGET_DIR]   Install Borris-Flow into TARGET_DIR (defaults to current directory).

Options:
  --force, -f    Overwrite existing files
  --help, -h     Show this help text
  --version, -V  Show version
EOF
}

version() {
  echo "${SCRIPT_NAME} ${VERSION}"
}

confirm() {
  local prompt="$1"
  while true; do
    read -r -p "${prompt} [y/N]: " reply
    case "$reply" in
      [yY]|[yY][eE][sS])
        return 0
        ;;
      [nN]|[nN][oO]|"")
        return 1
        ;;
      *)
        echo "Please enter y or n."
        ;;
    esac
  done
}

copy_template() {
  local target="$1"
  local force="$2"

  python3 - "$target" "$TEMPLATE_CLAUDE_DIR" "$TEMPLATE_CLAUDE_MD" "$force" <<'PY'
from pathlib import Path
import shutil
import sys

target = Path(sys.argv[1])
template_dir = Path(sys.argv[2])
template_md = Path(sys.argv[3])
force = sys.argv[4] == "1"


def sync(src: Path, dst: Path):
    if src.is_dir():
        # avoid copying generated worktrees if template accidentally contains them
        if src.name == "worktrees" and src.parent.name == ".claude":
            return
        dst.mkdir(parents=True, exist_ok=True)
        for child in src.iterdir():
            sync(child, dst / child.name)
        return

    if dst.exists() and not force:
        return

    dst.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(src, dst)


sync(template_dir, target / ".claude")
sync(template_md, target / "CLAUDE.md")
PY
}

run_init() {
  local target="."
  local force=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force|-f)
        force=true
        shift
        ;;
      --help|-h)
        usage
        return 0
        ;;
      *)
        if [[ "$target" == "." ]]; then
          target="$1"
          shift
        else
          echo "Error: too many positional arguments: $1" >&2
          usage
          return 1
        fi
        ;;
    esac
  done

  if [[ ! -d "$TEMPLATE_CLAUDE_DIR" || ! -f "$TEMPLATE_CLAUDE_MD" ]]; then
    echo "Error: template files missing from ${SCRIPT_DIR}" >&2
    return 1
  fi

  mkdir -p "$target"
  local target_abs
  target_abs="$(cd "$target" && pwd)"

  if ! confirm "Install Borris-Flow into '${target_abs}'?"; then
    echo "Aborted."
    return 0
  fi

  local force_flag="0"
  if [[ "$force" == true ]]; then
    force_flag="1"
  fi

  copy_template "$target_abs" "$force_flag"
  echo "Installed Borris-Flow into: ${target_abs}"
}

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

FORCE_GLOBAL=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;
    --version|-V)
      version
      exit 0
      ;;
    --force|-f)
      FORCE_GLOBAL=true
      shift
      ;;
    init)
      shift
      if [[ "$FORCE_GLOBAL" == true ]]; then
        run_init --force "$@"
      else
        run_init "$@"
      fi
      exit $?
      ;;
    *)
      echo "Error: unknown command: $1" >&2
      usage
      exit 1
      ;;
  esac
done
